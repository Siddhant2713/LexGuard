# ─── Mode ─────────────────────────────────────────────────────────────────────
DEMO_MODE=false

# ─── Firebase optional ────────────────────────────────────────────────────────
# Set USE_FIREBASE=false to run the full app with only a Groq key.
# Sessions are stored in-memory only (lost on server restart).
USE_FIREBASE=false

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Analysis model (Pass 1/2/3) — best JSON accuracy on free tier:
# GROQ_MODEL=llama-3.3-70b-versatile
# Chat streaming model — fastest output:
# GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Free tier: ~30 RPM — PASS2_CONCURRENCY=3 is safe; raise to 5 on paid tier
PASS2_CONCURRENCY=3

# ─── Firebase (required only when USE_FIREBASE=true) ─────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
