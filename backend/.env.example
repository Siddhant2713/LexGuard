# ─── Mode ─────────────────────────────────────────────────────────────────────
# Set to false in production. true = bypass all Gemini/Firebase calls.
DEMO_MODE=false

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ─── Optional: path to Firebase service account key (local dev only) ──────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# Note: The service account needs 'Firebase Storage Admin' and 'Cloud Datastore User' IAM roles.
