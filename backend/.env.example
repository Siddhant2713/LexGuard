# ─── Mode ─────────────────────────────────────────────────────────────────────
DEMO_MODE=false

# ─── Firebase optional ────────────────────────────────────────────────────────
# Set USE_FIREBASE=false to run the full app with only a Gemini key.
# Sessions are stored in-memory only (lost on server restart).
USE_FIREBASE=false

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# If gemini-2.5-flash gives a 404, use this instead (always available on free tier):
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_CHAT_MODEL=gemini-1.5-flash

# Free tier: PASS2_CONCURRENCY=2 to stay under 10 RPM
# Paid tier: PASS2_CONCURRENCY=5
PASS2_CONCURRENCY=2

# ─── Firebase (required only when USE_FIREBASE=true) ─────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
